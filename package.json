{
  "name": "friday-code",
  "version": "0.1.0",
  "description": "Friday Code — The open-source terminal AI agent. Built with React (Ink) and Vercel AI SDK.",
  "type": "module",
  "bin": {
    "friday": "./bin/friday.js"
  },
  "main": "./dist/index.js",
