    "yoga-wasm-web": "^0.3.3",
    "ink": "^5.2.0",
    "ink-text-input": "^6.0.0",
    "zod": "^3.24.0",
    "drizzle-orm": "^0.39.0",
    "better-sqlite3": "^11.8.0",
    "chalk": "^5.4.1",
    "cli-boxes": "^4.0.1",
    "cli-highlight": "^2.1.11",
    "marked": "^15.0.0",
    "marked-terminal": "^7.3.0",
